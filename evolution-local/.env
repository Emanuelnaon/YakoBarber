# ---- CONFIGURACIÓN DEL SERVIDOR ----
SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# ---- SEGURIDAD Y LLAVE MAESTRA ----
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=EmaNaon2026SecretoMaster

# ---- CONFIGURACIÓN DE BASE DE DATOS (PRISMA LATEST) ----
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:postgres@evolution_postgres:5432/evolution_db?schema=public

# ---- CONFIGURACIÓN DE CACHÉ (REDIS) ----
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution_redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution

# ---- LOGS PARA DIAGNÓSTICO ----
LOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG
LOG_COLOR=true
LOG_BAILEYS=error

# ---- SOLUCIÓN AL BUCLE DEL QR (INFO DEL VIDEO) ----
CONFIG_SESSION_PHONE_CLIENT=YakoBarberBot
CONFIG_SESSION_PHONE_NAME=Chrome
CONFIG_SESSION_PHONE_VERSION=2.3000.1023204200

# ---- DESACTIVAR AGENTES EXTERNOS INNECESARIOS POR AHORA ----
TELEMETRY_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false