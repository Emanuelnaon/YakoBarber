# Servidor
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Autenticación (Tu llave maestra)
AUTHENTICATION_API_KEY=EmaNaon2026Secreto

# Redis (Base para que el QR funcione)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://localhost:6379/6
CACHE_REDIS_PREFIX_KEY=evolution

# Base de Datos (Si vas a usar Supabase o local)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://user:pass@localhost:5432/evolution?schema=public

# Log para ver errores (Importante para debuguear)
LOG_LEVEL=ERROR,WARN,DEBUG,INFO